<mujoco>

    <option gravity="0 0 -9.81" timestep="0.002"/>

    <worldbody>

        <!-- ground -->
        <geom type="plane" size="10 10 0.1"/>

        <!-- moving platform -->
        <body name="platform" pos="0 0 0.2">

            <!-- ONLY x translation -->
            <joint
                name="platform_slide"
                type="slide"
                axis="1 0 0"
                damping="1"/>

            <geom
                type="box"
                size="1 0.3 0.1"
                rgba="0.2 0.2 0.8 1"/>

        </body>

    </worldbody>

</mujoco>